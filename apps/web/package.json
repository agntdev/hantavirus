{
  "name": "@hantavirus/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "test": "node --import tsx --test test/*.test.tsx",
    "test:coverage": "node --experimental-test-coverage --import tsx --test test/*.test.tsx",
    "typecheck": "tsc -b --pretty false",
    "lint": "tsc -b --pretty false",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "tsx": "^4.21.0",
    "vite": "^8.0.12"
  }
}
